---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

export async function getStaticPaths() {
  const docsEntries = await getCollection('docs');
  return docsEntries.map(entry => ({
    params: { slug: entry.id }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const formattedDate = entry.data.date ? new Date(entry.data.date).toLocaleDateString('ja-JP') : null;
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <Breadcrumbs items={[
    { label: 'Documents', href: '/docs' },
    { label: entry.data.category, href: `/docs` },
    { label: entry.data.title }
  ]} />
  
  <article class="prose prose-sakura max-w-none bg-white p-8 sm:p-10 rounded-2xl shadow-[0_4px_20px_-4px_rgba(252,231,243,0.5)] border border-sakura-100 mb-8">
    <header class="mb-8 border-b border-sakura-100 pb-6 not-prose">
      <div class="flex items-center gap-2 mb-2">
        <span class="inline-block px-3 py-1 bg-sakura-50 text-sakura-700 text-xs font-semibold rounded-full border border-sakura-200">
          {entry.data.category}
        </span>
        {formattedDate && <time class="text-sm text-gray-500">{formattedDate}</time>}
      </div>
      <h1 class="text-3xl sm:text-4xl font-bold text-sakura-950 leading-tight">{entry.data.title}</h1>
      {entry.data.description && <p class="text-lg text-gray-600 mt-4 leading-relaxed">{entry.data.description}</p>}
    </header>
    <div class="mdx-content">
      <Content />
    </div>
  </article>
</BaseLayout>

<style is:global>
  /* Custom prose overrides for MDX */
  .mdx-content h2 { margin-top: 2.5em; color: var(--color-sakura-800); border-bottom: 2px solid var(--color-sakura-100); padding-bottom: 0.3em; }
  .mdx-content h3 { margin-top: 2em; color: var(--color-sakura-700); }
  .mdx-content a { color: var(--color-sakura-600); text-decoration-thickness: 1px; text-underline-offset: 4px; transition: color 0.2s; }
  .mdx-content a:hover { color: var(--color-sakura-800); text-decoration-thickness: 2px; }
  .mdx-content blockquote { border-left-color: var(--color-sakura-300); background-color: var(--color-sakura-50); padding: 0.5em 1em; border-radius: 0 0.5rem 0.5rem 0; font-style: normal; }
  .mdx-content pre { background-color: #1e1e2e; border-radius: 0.75rem; padding: 1.25rem; font-size: 0.9em; box-shadow: inset 0 2px 4px 0 rgba(0,0,0,0.06); }
  .mdx-content code { background-color: var(--color-sakura-50); color: var(--color-sakura-700); padding: 0.2em 0.4em; border-radius: 0.25rem; font-size: 0.9em; font-weight: 500; }
  .mdx-content pre code { background-color: transparent; color: inherit; padding: 0; border-radius: 0; }
</style>
